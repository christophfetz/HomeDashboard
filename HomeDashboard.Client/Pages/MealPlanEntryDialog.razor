@using HomeDashboard.Client.Models.Entities

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsEdit ? "Eintrag bearbeiten" : "Mahlzeit eintragen")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @DayLabel — @MealTypeLabel
                </MudText>
            </MudItem>
            <MudItem xs="12">
                <MudAutocomplete T="Recipe"
                                 Label="Rezept (optional)"
                                 @bind-Value="_selectedRecipe"
                                 SearchFunc="SearchRecipes"
                                 ToStringFunc="@(r => r?.Title ?? "")"
                                 Variant="Variant.Outlined"
                                 ShrinkLabel="true"
                                 Clearable="true"
                                 MinCharacters="0"
                                 ResetValueOnEmptyText="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Notiz (optional)"
                              @bind-Value="_note"
                              Variant="Variant.Outlined"
                              ShrinkLabel="true"
                              Lines="2"
                              Placeholder="z.B. Gäste kommen um 19 Uhr" />
            </MudItem>
            @if (_showValidation && !IsValid)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Bitte entweder ein Rezept wählen oder eine Notiz eingeben.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        @if (IsEdit)
        {
            <MudButton Color="Color.Error"
                       OnClick="DeleteEntry"
                       StartIcon="@Icons.Material.Filled.Delete">
                Löschen
            </MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save">
            Speichern
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public string DayLabel { get; set; } = "";
    [Parameter] public string MealTypeLabel { get; set; } = "";
    [Parameter] public List<Recipe> AllRecipes { get; set; } = new();
    [Parameter] public Recipe? InitialRecipe { get; set; }
    [Parameter] public string? InitialNote { get; set; }

    private Recipe? _selectedRecipe;
    private string _note = "";
    private bool _showValidation = false;

    private bool IsValid => _selectedRecipe != null || !string.IsNullOrWhiteSpace(_note);

    protected override void OnParametersSet()
    {
        _selectedRecipe = InitialRecipe;
        _note = InitialNote ?? "";
    }

    private Task<IEnumerable<Recipe>> SearchRecipes(string value, CancellationToken ct)
    {
        IEnumerable<Recipe> results = string.IsNullOrEmpty(value)
            ? AllRecipes
            : AllRecipes.Where(r => r.Title.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private void Cancel() => MudDialog.Cancel();

    private void Save()
    {
        _showValidation = true;
        if (!IsValid) return;

        MudDialog.Close(DialogResult.Ok(new MealPlanDialogResult
        {
            Recipe = _selectedRecipe,
            Note = _note.Trim()
        }));
    }

    private void DeleteEntry() => MudDialog.Close(DialogResult.Ok(new MealPlanDialogResult
    {
        Delete = true
    }));
}
